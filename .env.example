# Copy to `.env` for local development. Only EXPO_PUBLIC_* variables are available in the JS bundle.
#
# Remote dev (Expo Go from anywhere): `npm run start:tunnel` or `npx expo start --tunnel`
# Point the API at your deployed server — tunnel only affects Metro ↔ phone, not the API host.

# API origin — no trailing slash, no /api suffix. Defaults to deployed backend in `services/api.ts` if unset.
EXPO_PUBLIC_API_URL=https://keygo-server.onrender.com

# Mapbox (native Mapbox build only). Leave empty for MapLibre dev or react-native-maps / Expo Go.
# EXPO_PUBLIC_MAPBOX_TOKEN=

# Dev-only: use MapLibre + free tiles instead of Mapbox (requires dev client + native module). Ignored in production.
# EXPO_PUBLIC_USE_MAPLIBRE=1
